# Cloudflare Pages custom headers

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()


/* Security + Defaults */
/* Apply site-wide security headers */
/* Note: HSTS only applies on HTTPS in production */
/
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

/* HTML pages: short cache so updates propagate quickly */
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/* root document */
/index.html
  Cache-Control: public, max-age=0, must-revalidate
  Permissions-Policy: gamepad=*, autoplay=*, fullscreen=*

/* JS/CSS: long-term caching, immutable, and vary on Accept-Encoding */
/js/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

/css/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

/* Assets (images/fonts): long cache and compressed negotiation */
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

/* Service worker: ensure browser checks for updates */
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

/* Game pages (dynamic-ish): short cache but allow stale while revalidate */
/game/*/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/* Fallback for other static files (fonts, icons) */
/* e.g. assets/icon/* already covered; these provide a safe default */
/assets/icon/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

